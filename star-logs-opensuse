splash "Star Labs Diagnostics"
red=$(tput setaf 1)
green=$(tput setaf 2)
normal=$(tput sgr0)

if [ "$EUID" -ne 0 ];then
	printf "\nStar-Logs requires root priveldges. Please type in:\n\n"
	printf "%s\n\n" "${green}sudo star-logs"
	exit
fi

CBMEM_URL="https://raw.githubusercontent.com/StarLabsLtd/firmware/refs/heads/26.06/binaries/cbmem"

function get_cbmem_binary() {
	local cbmem_path="/tmp/starlabs-cbmem"

	if command -v cbmem &> /dev/null; then
		command -v cbmem
		return 0
	fi

	if ! command -v curl &> /dev/null; then
		return 1
	fi

	if ! [ -x "$cbmem_path" ]; then
		curl -fsSL "$CBMEM_URL" -o "$cbmem_path" || return 1
		chmod +x "$cbmem_path" || return 1
	fi

	printf "%s\n" "$cbmem_path"
}

function collect_cbmem_logs() {
	local bios_vendor cbmem_bin

	bios_vendor="$(cat /sys/class/dmi/id/bios_vendor 2> /dev/null || true)"
	if ! printf "%s" "$bios_vendor" | grep -qi "coreboot"; then
		printf "BIOS vendor is not coreboot; skipping cbmem.\n" > "$log_dir/cbmem.txt"
		return 0
	fi

	if ! cbmem_bin="$(get_cbmem_binary)"; then
		printf "Unable to find or download cbmem.\n" > "$log_dir/cbmem.txt"
		return 0
	fi

	{
		printf "### cbmem table\n"
		"$cbmem_bin" -l
		printf "\n### cbmem last boot console\n"
		"$cbmem_bin" -1
		printf "\n### cbmem timestamps\n"
		"$cbmem_bin" -t
	} &> "$log_dir/cbmem.txt"
}

function command_to_file() {
	local output_path="$1"
	shift

	if command -v "$1" &> /dev/null; then
		"$@" &> "$output_path"
	else
		printf "%s is not installed.\n" "$1" > "$output_path"
	fi
}

function collect_dmi_sysfs() {
	mkdir -p "$log_dir/dmi-sysfs"

	for f in /sys/class/dmi/id/*; do
		[ -f "$f" ] || continue
		cat "$f" > "$log_dir/dmi-sysfs/$(basename "$f")" 2> /dev/null || true
	done
}

function collect_pstore() {
	mkdir -p "$log_dir/pstore"

	if ! [ -d /sys/fs/pstore ]; then
		printf "/sys/fs/pstore is not available.\n" > "$log_dir/pstore/list.txt"
		return 0
	fi

	ls -la /sys/fs/pstore > "$log_dir/pstore/list.txt" 2>&1
	for f in /sys/fs/pstore/*; do
		[ -f "$f" ] || continue
		cat "$f" > "$log_dir/pstore/$(basename "$f")" 2> /dev/null || true
	done
}

function collect_intel_rapl() {
	local rapl_files

	if ! [ -d /sys/class/powercap ]; then
		printf "/sys/class/powercap is not available.\n" > "$log_dir/intel-rapl.txt"
		return 0
	fi

	rapl_files="$(find -L /sys/class/powercap -type f -path '*intel-rapl*' 2> /dev/null | sort)"
	if [ -z "$rapl_files" ]; then
		printf "No Intel RAPL entries found.\n" > "$log_dir/intel-rapl.txt"
		return 0
	fi

	{
		while read -r f; do
			printf "### %s\n" "$f"
			cat "$f" 2> /dev/null || true
			printf "\n"
		done <<< "$rapl_files"
	} > "$log_dir/intel-rapl.txt"
}

function collect_nvme() {
	{
		if [ -d /sys/class/nvme ]; then
			printf "### /sys/class/nvme\n"
			ls -la /sys/class/nvme
			printf "\n"
			for controller in /sys/class/nvme/nvme*; do
				[ -d "$controller" ] || continue
				printf "### %s\n" "$controller"
				for field in model serial firmware_rev state transport address; do
					[ -f "$controller/$field" ] || continue
					printf "%s: " "$field"
					cat "$controller/$field" 2> /dev/null || true
				done
				printf "\n"
			done
		else
			printf "/sys/class/nvme is not available.\n"
		fi

		if command -v nvme &> /dev/null; then
			printf "\n### nvme list\n"
			nvme list
			for dev in /dev/nvme[0-9]; do
				[ -e "$dev" ] || continue
				printf "\n### nvme smart-log %s\n" "$dev"
				nvme smart-log "$dev" 2>&1 || true
			done
		else
			printf "\nnvme-cli is not installed.\n"
		fi
	} > "$log_dir/nvme.txt" 2>&1
}

function get_output_dir() {
	local owner="${SUDO_USER:-$(id -un)}"
	local owner_home output_dir

	owner_home="$(getent passwd "$owner" | cut -d ':' -f 6)"
	if [ -z "$owner_home" ]; then
		owner_home="$HOME"
	fi

	if [ "$owner" != "root" ] && command -v runuser &> /dev/null; then
		output_dir="$(runuser -u "$owner" -- xdg-user-dir DOWNLOAD 2> /dev/null || true)"
	elif command -v xdg-user-dir &> /dev/null; then
		output_dir="$(xdg-user-dir DOWNLOAD 2> /dev/null || true)"
	fi

	if [ -z "$output_dir" ] || ! [ -d "$output_dir" ]; then
		output_dir="$owner_home"
	fi

	printf "%s\n" "$output_dir"
}

function create_archive() {
	local archive_base output_dir

	archive_base="$(basename "$log_dir")"
	output_dir="$(get_output_dir)"

	if command -v zip &> /dev/null; then
		archive_path="$output_dir/$archive_base.zip"
		(cd "$log_dir" && zip -r "$archive_path" .) &> /dev/null
	else
		archive_path="$output_dir/$archive_base.tar.gz"
		tar -czf "$archive_path" -C "$log_dir" . &> /dev/null
	fi

	if [ -n "${SUDO_USER:-}" ] && [ "$SUDO_USER" != "root" ]; then
		chown "$SUDO_USER:" "$archive_path" 2> /dev/null || true
	fi
}

log_dir="/tmp/$(cat /sys/class/dmi/id/product_name)_$(date '+%Y-%m-%d_%H-%M-%S')"

mkdir -p "$log_dir"

printf "%-35s %s" "${normal}Journalctl:"
journalctl -r --since "3 days ago"				&> "$log_dir/journalctl.txt"
printf "%s\n" "${green}✔"

printf "%-35s %s" "${normal}Boot log:"
journalctl -r --list-boots					&> "$log_dir/boot.txt"
printf "%s\n" "${green}✔"

printf "%-35s %s" "${normal}Dmesg:"
dmesg								&> "$log_dir/dmesg.txt"
printf "%s\n" "${green}✔"

printf "%-35s %s" "${normal}Pstore:"
collect_pstore
printf "%s\n" "${green}✔"

printf "%-35s %s" "${normal}Coreboot memory log:"
collect_cbmem_logs
printf "%s\n" "${green}✔"

printf "%-35s %s" "${normal}Firmware information:"
command_to_file "$log_dir/fwupd.txt" fwupdmgr --version
command_to_file "$log_dir/fwupd-devices.txt" fwupdmgr get-devices --show-all-devices --json
command_to_file "$log_dir/fwupd-flashrom.txt" fwupdtool get-devices --plugins flashrom --verbose
command_to_file "$log_dir/fwupd-security.txt" fwupdmgr security --force
command_to_file "$log_dir/dmi.txt" dmidecode
collect_dmi_sysfs
printf "%s\n" "${green}✔"

printf "%-35s %s" "${normal}Distribution information:"
cat /etc/os-release							&> "$log_dir/distro.txt"
uname -r							&> "$log_dir/kernel.txt"
printf "%s\n" "${green}✔"

printf "%-35s %s" "${normal}Battery information:"
upower -i /org/freedesktop/UPower/devices/battery_BAT0		&> "$log_dir/battery.txt"
printf "%s\n" "${green}✔"

printf "%-35s %s" "${normal}Intel RAPL:"
collect_intel_rapl
printf "%s\n" "${green}✔"

printf "%-35s %s" "${normal}Installed programs:"
zypper search -i						&> "$log_dir/installed.txt"
zypper list-updates						&> "$log_dir/upgradeable.txt"
printf "%s\n" "${green}✔"

printf "%-35s %s" "${normal}Package sources:"
mkdir -p "$log_dir/repo"
for f in /etc/zypp/repos.d/*.repo; do
	cat "$f"						&> "$log_dir/repo/$(echo $f | cut -d '/' -f5)"
done
printf "%s\n" "${green}✔"

printf "%-35s %s" "${normal}Kernel config:"
mkdir "$log_dir/modprobe"
for f in /etc/modprobe.d/*; do
        cat "$f"						&> "$log_dir/modprobe/$(echo $f | cut -d '/' -f4)"
done
printf "%s\n" "${green}✔"

printf "%-35s %s" "${normal}PCI devices:"
lspci -vvvnnnxxx						&> "$log_dir/pci.txt"
printf "%s\n" "${green}✔"

printf "%-35s %s" "${normal}NVMe:"
collect_nvme
printf "%s\n" "${green}✔"

printf "%-35s %s" "${normal}Getting audio codec:"
cat /proc/asound/card0/codec#0					&> "$log_dir/codec.txt"
printf "%s\n" "${green}✔"

if [[ $(cat /sys/class/dmi/id/bios_vendor) == "coreboot" ]]; then
	if ! [ -x "$(command -v nvramtool)" ]; then
		zypper -n install coreboot-utils
	fi
	printf "%-35s %s" "${normal}NVRAM:"
	nvramtool -a						&> "$log_dir/nvram.txt"
	printf "%s\n" "${green}✔"
fi

if command -v snap &> /dev/null; then
	printf "%-35s %s" "${normal}Installed snaps:"
	snap list						&> "$log_dir/snap.txt"
	printf "%s\n" "${green}✔"
fi

create_archive
printf "\n${normal}Logs have been saved to ${green}%s\n" "$archive_path"
