#!/bin/bash
function splash() {
action="$1"
# clear
cat << "EOF"

╔═════════════════════════════════════════════════════════════════════════════╗
║                                                                             ║
║                    ██╗      ██████╗  ██████╗ ███████╗                       ║
║                    ██║     ██╔═══██╗██╔════╝ ██╔════╝                       ║
║                    ██║     ██║   ██║██║  ███╗███████╗                       ║
║                    ██║     ██║   ██║██║   ██║╚════██║                       ║
║                    ███████╗╚██████╔╝╚██████╔╝███████║                       ║
