splash "Star Labs Diagnostics"
green=$(tput setaf 2)
normal=$(tput sgr0)

if [ "$EUID" -ne 0 ];then
	printf "\nStar-Logs requires root privileges. Please type in:\n\n"
	printf "%s\n\n" "${green}sudo star-logs"
	exit 1
fi

CBMEM_URL="https://raw.githubusercontent.com/StarLabsLtd/firmware/refs/heads/26.06/binaries/cbmem"

function get_cbmem_binary() {
	local cbmem_path="/tmp/starlabs-cbmem"

	if command -v cbmem &> /dev/null; then
		command -v cbmem
		return 0
	fi

	if ! command -v curl &> /dev/null; then
		return 1
	fi

	if ! [ -x "$cbmem_path" ]; then
		curl -fsSL "$CBMEM_URL" -o "$cbmem_path" || return 1
		chmod +x "$cbmem_path" || return 1
	fi

	printf "%s\n" "$cbmem_path"
}

function collect_cbmem_logs() {
	local bios_vendor cbmem_bin

	bios_vendor="$(cat /sys/class/dmi/id/bios_vendor 2> /dev/null || true)"
	if ! printf "%s" "$bios_vendor" | grep -qi "coreboot"; then
		printf "BIOS vendor is not coreboot; skipping cbmem.\n" > "$log_dir/cbmem.txt"
		return 0
	fi

	if ! cbmem_bin="$(get_cbmem_binary)"; then
		printf "Unable to find or download cbmem.\n" > "$log_dir/cbmem.txt"
		return 0
	fi

	{
		printf "### cbmem table\n"
		"$cbmem_bin" -l
		printf "\n### cbmem last boot console\n"
		"$cbmem_bin" -1
		printf "\n### cbmem timestamps\n"
		"$cbmem_bin" -t
	} &> "$log_dir/cbmem.txt"
}

function command_to_file() {
	local output_path="$1"
	shift

	if command -v "$1" &> /dev/null; then
		"$@" &> "$output_path" || true
	else
		printf "%s is not installed.\n" "$1" > "$output_path"
	fi
}

function append_command_to_file() {
	local output_path="$1"
	local title="$2"
	shift 2

	{
		printf "### %s\n" "$title"
		if command -v "$1" &> /dev/null; then
			"$@" 2>&1 || true
		else
			printf "%s is not installed.\n" "$1"
		fi
		printf "\n"
	} >> "$output_path"
}

function collect_dmi_sysfs() {
	mkdir -p "$log_dir/dmi-sysfs"

	for f in /sys/class/dmi/id/*; do
		[ -f "$f" ] || continue
		cat "$f" > "$log_dir/dmi-sysfs/$(basename "$f")" 2> /dev/null || true
	done
}

function collect_pstore() {
	mkdir -p "$log_dir/pstore"

	if ! [ -d /sys/fs/pstore ]; then
		printf "/sys/fs/pstore is not available.\n" > "$log_dir/pstore/list.txt"
		return 0
	fi

	ls -la /sys/fs/pstore > "$log_dir/pstore/list.txt" 2>&1
	for f in /sys/fs/pstore/*; do
		[ -f "$f" ] || continue
		cat "$f" > "$log_dir/pstore/$(basename "$f")" 2> /dev/null || true
	done
}

function collect_intel_rapl() {
	local rapl_files rapl_zones

	if ! [ -d /sys/class/powercap ]; then
		printf "/sys/class/powercap is not available.\n" > "$log_dir/intel-rapl.txt"
		return 0
	fi

	rapl_zones="$(find -L /sys/class/powercap -type d -name 'intel-rapl*' 2> /dev/null \
		| while read -r zone; do realpath "$zone" 2> /dev/null || printf "%s\n" "$zone"; done \
		| sort -u)"
	rapl_files="$(find -L /sys/class/powercap -type f -path '*intel-rapl*' 2> /dev/null \
		| while read -r file; do realpath "$file" 2> /dev/null || printf "%s\n" "$file"; done \
		| sort -u)"
	if [ -z "$rapl_files" ]; then
		printf "No Intel RAPL entries found.\n" > "$log_dir/intel-rapl.txt"
		return 0
	fi

	{
		printf "### Intel RAPL limit summary\n"
		while read -r zone; do
			[ -d "$zone" ] || continue
			printf "## %s\n" "$zone"

			for field in name enabled energy_uj max_energy_range_uj; do
				[ -f "$zone/$field" ] || continue
				local value
				value="$(cat "$zone/$field" 2> /dev/null || true)"
				printf "%s: %s\n" "$field" "$value"
			done

			for limit in "$zone"/constraint_*_power_limit_uw; do
				[ -f "$limit" ] || continue
				local constraint="${limit##*/constraint_}"
				constraint="${constraint%_power_limit_uw}"

				for field in \
					"constraint_${constraint}_name" \
					"constraint_${constraint}_power_limit_uw" \
					"constraint_${constraint}_max_power_uw" \
					"constraint_${constraint}_time_window_us"; do
					[ -f "$zone/$field" ] || continue
					value="$(cat "$zone/$field" 2> /dev/null || true)"
					printf "%s: %s" "$field" "$value"
					if [[ "$field" == *_uw ]] && [[ "$value" =~ ^[0-9]+$ ]]; then
						awk -v value="$value" 'BEGIN { printf " (%.2f W)", value / 1000000 }'
					elif [[ "$field" == *_us ]] && [[ "$value" =~ ^[0-9]+$ ]]; then
						awk -v value="$value" 'BEGIN { printf " (%.2f s)", value / 1000000 }'
					fi
					printf "\n"
				done
			done
			printf "\n"
		done <<< "$rapl_zones"

		printf "### Raw Intel RAPL attribute dump\n"
		while read -r f; do
			printf "### %s\n" "$f"
			cat "$f" 2> /dev/null || true
			printf "\n"
		done <<< "$rapl_files"
	} > "$log_dir/intel-rapl.txt"
}

function collect_nvme() {
	{
		if [ -d /sys/class/nvme ]; then
			printf "### /sys/class/nvme\n"
			ls -la /sys/class/nvme
			printf "\n"
			for controller in /sys/class/nvme/nvme*; do
				[ -d "$controller" ] || continue
				printf "### %s\n" "$controller"
				for field in model serial firmware_rev state transport address; do
					[ -f "$controller/$field" ] || continue
					printf "%s: " "$field"
					cat "$controller/$field" 2> /dev/null || true
				done
				printf "\n"
			done
		else
			printf "/sys/class/nvme is not available.\n"
		fi

		if command -v nvme &> /dev/null; then
			printf "\n### nvme list\n"
			nvme list
			for dev in /dev/nvme[0-9]; do
				[ -e "$dev" ] || continue
				printf "\n### nvme smart-log %s\n" "$dev"
				nvme smart-log "$dev" 2>&1 || true
			done
		else
			printf "\nnvme-cli is not installed.\n"
		fi
	} > "$log_dir/nvme.txt" 2>&1
}

function collect_usb() {
	{
		append_command_to_file /dev/stdout "lsusb" lsusb
		append_command_to_file /dev/stdout "lsusb tree" lsusb -t
		append_command_to_file /dev/stdout "lsusb verbose" lsusb -v
		append_command_to_file /dev/stdout "usb-devices" usb-devices
		printf "### USB sysfs\n"
		for device in /sys/bus/usb/devices/*; do
			[ -d "$device" ] || continue
			printf "\n## %s\n" "$device"
			for field in busnum devnum devpath idVendor idProduct bcdDevice manufacturer product serial version speed; do
				[ -f "$device/$field" ] || continue
				printf "%s: " "$field"
				cat "$device/$field" 2> /dev/null || true
			done
		done
	} > "$log_dir/usb.txt" 2>&1
}

function collect_distribution_info() {
	: > "$log_dir/distro.txt"

	if [ -f /etc/os-release ]; then
		{
			printf "### /etc/os-release\n"
			cat /etc/os-release
			printf "\n"
		} >> "$log_dir/distro.txt"
	fi

	append_command_to_file "$log_dir/distro.txt" "lsb_release" lsb_release -a
	uname -r &> "$log_dir/kernel.txt" || true
}

function collect_package_info() {
	if command -v apt &> /dev/null; then
		apt list --installed &> "$log_dir/installed.txt" || true
		apt list --upgradeable &> "$log_dir/upgradeable.txt" || true
		return 0
	fi

	if command -v pacman &> /dev/null; then
		pacman -Qe &> "$log_dir/installed.txt" || true
		pacman -Qu &> "$log_dir/upgradeable.txt" || true
		return 0
	fi

	if command -v dnf &> /dev/null; then
		dnf list installed &> "$log_dir/installed.txt" || true
		dnf check-update &> "$log_dir/upgradeable.txt" || true
		return 0
	fi

	if command -v zypper &> /dev/null; then
		zypper search -i &> "$log_dir/installed.txt" || true
		zypper list-updates &> "$log_dir/upgradeable.txt" || true
		return 0
	fi

	printf "No supported package manager found.\n" > "$log_dir/installed.txt"
	printf "No supported package manager found.\n" > "$log_dir/upgradeable.txt"
}

function collect_matching_files() {
	local output_dir="$1"
	local empty_message="$2"
	local pattern file safe_name found=0
	shift 2

	mkdir -p "$output_dir"
	for pattern in "$@"; do
		while IFS= read -r file; do
			[ -f "$file" ] || continue
			safe_name="${file#/etc/}"
			safe_name="${safe_name//\//__}"
			cat "$file" > "$output_dir/$safe_name" 2> /dev/null || true
			found=1
		done < <(compgen -G "$pattern" || true)
	done

	if [ "$found" -eq 0 ]; then
		printf "%s\n" "$empty_message" > "$output_dir/none.txt"
	fi
}

function collect_package_sources() {
	collect_matching_files "$log_dir/repo" \
		"No package source files found." \
		"/etc/apt/sources.list" \
		"/etc/apt/sources.list.d/*.list" \
		"/etc/apt/sources.list.d/*.sources" \
		"/etc/pacman.conf" \
		"/etc/pacman.d/mirrorlist" \
		"/etc/yum.repos.d/*.repo" \
		"/etc/zypp/repos.d/*.repo"
}

function collect_modprobe_config() {
	collect_matching_files "$log_dir/modprobe" \
		"No modprobe configuration files found." \
		"/etc/modprobe.d/*"
}

function get_output_dir() {
	local owner="${SUDO_USER:-$(id -un)}"
	local owner_home output_dir

	owner_home="$(getent passwd "$owner" | cut -d ':' -f 6)"
	if [ -z "$owner_home" ]; then
		owner_home="$HOME"
	fi

	if [ "$owner" != "root" ] && command -v runuser &> /dev/null; then
		output_dir="$(runuser -u "$owner" -- xdg-user-dir DOWNLOAD 2> /dev/null || true)"
	elif command -v xdg-user-dir &> /dev/null; then
		output_dir="$(xdg-user-dir DOWNLOAD 2> /dev/null || true)"
	fi

	if [ -z "$output_dir" ] || ! [ -d "$output_dir" ]; then
		output_dir="$owner_home"
	fi

	printf "%s\n" "$output_dir"
}

function create_archive() {
	local archive_base output_dir

	archive_base="$(basename "$log_dir")"
	output_dir="$(get_output_dir)"

	if command -v zip &> /dev/null; then
		archive_path="$output_dir/$archive_base.zip"
		(cd "$log_dir" && zip -r "$archive_path" .) &> /dev/null
	else
		archive_path="$output_dir/$archive_base.tar.gz"
		tar -czf "$archive_path" -C "$log_dir" . &> /dev/null
	fi

	if [ -n "${SUDO_USER:-}" ] && [ "$SUDO_USER" != "root" ]; then
		chown "$SUDO_USER:" "$archive_path" 2> /dev/null || true
	fi
}

log_dir="/tmp/$(cat /sys/class/dmi/id/product_name)_$(date '+%Y-%m-%d_%H-%M-%S')"

mkdir -p "$log_dir"

printf "%-35s" "${normal}Journalctl:"
journalctl -r --since "3 days ago"				&> "$log_dir/journalctl.txt"
printf "%s\n" "${green}✔"

printf "%-35s" "${normal}Boot log:"
journalctl -r --list-boots					&> "$log_dir/boot.txt"
printf "%s\n" "${green}✔"

printf "%-35s" "${normal}Dmesg:"
dmesg								&> "$log_dir/dmesg.txt"
printf "%s\n" "${green}✔"

printf "%-35s" "${normal}Pstore:"
collect_pstore
printf "%s\n" "${green}✔"

printf "%-35s" "${normal}Coreboot memory log:"
collect_cbmem_logs
printf "%s\n" "${green}✔"

printf "%-35s" "${normal}Firmware information:"
command_to_file "$log_dir/fwupd.txt" fwupdmgr --version
command_to_file "$log_dir/fwupd-devices.txt" fwupdmgr get-devices --show-all-devices --verbose
command_to_file "$log_dir/fwupd-flashrom.txt" fwupdtool get-devices --plugins flashrom --verbose
command_to_file "$log_dir/fwupd-security.txt" fwupdmgr security --force
command_to_file "$log_dir/dmi.txt" dmidecode
collect_dmi_sysfs
printf "%s\n" "${green}✔"

printf "%-35s" "${normal}Distribution information:"
collect_distribution_info
printf "%s\n" "${green}✔"

printf "%-35s" "${normal}Battery information:"
upower -i /org/freedesktop/UPower/devices/battery_BAT0		&> "$log_dir/battery.txt"
printf "%s\n" "${green}✔"

printf "%-35s" "${normal}Intel RAPL:"
collect_intel_rapl
printf "%s\n" "${green}✔"

printf "%-35s" "${normal}Installed programs:"
collect_package_info
printf "%s\n" "${green}✔"

printf "%-35s" "${normal}Package sources:"
collect_package_sources
printf "%s\n" "${green}✔"

printf "%-35s" "${normal}Kernel config:"
collect_modprobe_config
printf "%s\n" "${green}✔"

printf "%-35s" "${normal}PCI devices:"
lspci -vvvnnnxxx						&> "$log_dir/pci.txt"
printf "%s\n" "${green}✔"

printf "%-35s" "${normal}USB devices:"
collect_usb
printf "%s\n" "${green}✔"

printf "%-35s" "${normal}NVMe:"
collect_nvme
printf "%s\n" "${green}✔"

printf "%-35s" "${normal}Getting audio codec:"
cat /proc/asound/card0/codec#0					&> "$log_dir/codec.txt"
printf "%s\n" "${green}✔"

if [[ $(cat /sys/class/dmi/id/bios_vendor) == "coreboot" ]]; then
	printf "%-35s" "${normal}NVRAM:"
	command_to_file "$log_dir/nvram.txt" nvramtool -a
	printf "%s\n" "${green}✔"
fi

if command -v snap &> /dev/null; then
	printf "%-35s" "${normal}Installed snaps:"
	snap list						&> "$log_dir/snap.txt"
	printf "%s\n" "${green}✔"
fi

create_archive
printf "\n${normal}Logs have been saved to ${green}%s\n" "$archive_path"
