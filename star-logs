#!/bin/bash

function splash() {
    local system_name="$1"
    cat <<'BANNER'

╔═════════════════════════════════════════════════════════════════════════════╗
║                                                                             ║
║                    ██╗      ██████╗  ██████╗ ███████╗                       ║
║                    ██║     ██╔═══██╗██╔════╝ ██╔════╝                       ║
║                    ██║     ██║   ██║██║  ███╗███████╗                       ║
║                    ██║     ██║   ██║██║   ██║╚════██║                       ║
║                    ███████╗╚██████╔╝╚██████╔╝███████║                       ║
║                    ╚══════╝ ╚═════╝  ╚═════╝ ╚══════╝                       ║
╚═════════════════════════════════════════════════════════════════════════════╝
BANNER
    printf "╔═════════════════════════════════════════════════════════════════════════════╗\n"
    printf "%-79s %s\n" "║ Gathering logs: ${system_name}" "║ "
    printf "╚═════════════════════════════════════════════════════════════════════════════╝\n\n"
}

product_name=$(< /sys/class/dmi/id/product_name)
bios_vendor=$(< /sys/class/dmi/id/bios_vendor)

splash "$product_name"

if command -v tput &> /dev/null && [ -n "${TERM:-}" ]; then
    red=$(tput setaf 1)
    green=$(tput setaf 2)
    normal=$(tput sgr0)
else
    red=""
    green=""
    normal=""
fi

success_mark="✔"
failure_mark="✖"

run_and_log() {
    local label="$1"
    local outfile="$2"
    shift 2

    printf "%-35s %s" "${normal}${label}:" ""
    if "$@" &> "$outfile"; then
        printf "%s\n" "${green}${success_mark}${normal}"
        return 0
    else
        printf "%s\n" "${red}${failure_mark}${normal}"
        printf "%s\n" "${red}  ↳ See ${outfile} for details${normal}"
        return 1
    fi
}

if [ "$EUID" -ne 0 ]; then
    printf "\nStar-Logs requires root privileges. Please run with sudo.\n\n"
    exit 1
fi

output_user=${SUDO_USER:-$USER}
user_home=$(eval echo "~${output_user}")
if [ "$user_home" = "~${output_user}" ]; then
    user_home="/home/${output_user}"
fi
downloads_dir="${user_home}/Downloads"

if command -v fwupdmgr &> /dev/null; then
    if ! fwupdmgr get-updates 2>&1 | grep -q 'No updates'; then
        printf "Your firmware is not up to date. Updating the firmware may\n"
        printf "resolve the issue you are experiencing.\n\n"
        printf "Please see the below guide on how to update your firmware.\n\n"
        printf "https://support.starlabs.systems/kb/firmware/getting-started\n\n"
    fi
else
    printf "%sSkipping firmware update check; fwupdmgr not installed.%s\n\n" "$red" "$normal"
fi

log_dir="/tmp/${product_name}_$(date '+%Y-%m-%d_%H-%M-%S')"
mkdir -p "$log_dir"
zip_log="$log_dir/zip.log"

shopt -s nullglob

run_and_log "Journalctl" "$log_dir/journalctl.txt" journalctl -r --since "3 days ago"
run_and_log "Boot log" "$log_dir/boot.txt" journalctl -r --list-boots
run_and_log "Dmesg" "$log_dir/dmesg.txt" dmesg

if command -v fwupdmgr &> /dev/null; then
    run_and_log "fwupd version" "$log_dir/fwupd.txt" fwupdmgr --version
    run_and_log "fwupd devices" "$log_dir/fwupd-devices.txt" fwupdmgr get-devices --show-all-devices --verbose
    if command -v fwupdtool &> /dev/null; then
        run_and_log "fwupd flashrom devices" "$log_dir/fwupd-flashrom.txt" fwupdtool get-devices --plugins flashrom --verbose
    fi
    run_and_log "fwupd security" "$log_dir/fwupd-security.txt" fwupdmgr security --force
fi

run_and_log "DMI decode" "$log_dir/dmi.txt" dmidecode
run_and_log "Distribution information" "$log_dir/distro.txt" lsb_release -a
run_and_log "Kernel version" "$log_dir/kernel.txt" uname -r
run_and_log "Battery information" "$log_dir/battery.txt" upower -i /org/freedesktop/UPower/devices/battery_BAT0
run_and_log "Installed programs" "$log_dir/installed.txt" apt list --installed
run_and_log "Upgradeable programs" "$log_dir/upgradeable.txt" apt list --upgradeable

printf "%-35s %s" "${normal}Package sources:" ""
repo_status=0
repo_dir="$log_dir/repo"
mkdir -p "$repo_dir"
repo_files=(/etc/apt/sources.list.d/*.list)
if ((${#repo_files[@]})); then
    for f in "${repo_files[@]}"; do
        if ! cat "$f" &> "$repo_dir/$(basename "$f")"; then
            repo_status=1
        fi
    done
else
    if [ -f /etc/apt/sources.list ]; then
        cat /etc/apt/sources.list &> "$repo_dir/sources.list" || repo_status=1
    else
        repo_status=1
    fi
fi
if [ $repo_status -eq 0 ]; then
    printf "%s\n" "${green}${success_mark}${normal}"
else
    printf "%s\n" "${red}${failure_mark}${normal}"
    printf "%s\n" "${red}  ↳ Unable to copy APT sources${normal}"
fi

printf "%-35s %s" "${normal}Kernel config:" ""
modprobe_status=0
modprobe_dir="$log_dir/modprobe"
mkdir -p "$modprobe_dir"
for f in /etc/modprobe.d/*; do
    [[ -f "$f" ]] || continue
    if ! cat "$f" &> "$modprobe_dir/$(basename "$f")"; then
        modprobe_status=1
    fi
done
if [ $modprobe_status -eq 0 ]; then
    printf "%s\n" "${green}${success_mark}${normal}"
else
    printf "%s\n" "${red}${failure_mark}${normal}"
    printf "%s\n" "${red}  ↳ Unable to copy /etc/modprobe.d files${normal}"
fi

run_and_log "PCI devices" "$log_dir/pci.txt" lspci -vvvnnnxxx
run_and_log "Audio codec" "$log_dir/codec.txt" cat /proc/asound/card0/codec#0

if [[ "$bios_vendor" == "coreboot" ]]; then
    run_and_log "NVRAM" "$log_dir/nvram.txt" nvramtool -a
fi

if command -v snap &> /dev/null; then
    run_and_log "Installed snaps" "$log_dir/snap.txt" snap list
fi

archive_basename=$(basename "$log_dir")
archive_path="${downloads_dir}/${archive_basename}.zip"

if ! command -v zip &> /dev/null; then
    printf "%szip command not found. Logs remain in %s.%s\n" "$red" "$log_dir" "$normal"
    exit 0
fi

if [ ! -d "$downloads_dir" ]; then
    if ! mkdir -p "$downloads_dir"; then
        printf "%sUnable to create %s. Logs remain in %s.%s\n" "$red" "$downloads_dir" "$log_dir" "$normal"
        exit 1
    fi
fi

archive_status=0
if pushd "$log_dir" > /dev/null; then
    if ! zip -r "$archive_path" . &> "$zip_log"; then
        archive_status=1
    fi
    popd > /dev/null
else
    archive_status=1
fi

if [ $archive_status -eq 0 ]; then
    chown "$output_user:$output_user" "$archive_path" 2> /dev/null || true
    printf "\n${normal}Logs have been saved to ${green}~/Downloads/${archive_basename}.zip${normal}\n"
else
    printf "%sFailed to create archive. See %s for details. Logs remain in %s.%s\n" "$red" "$zip_log" "$log_dir" "$normal"
fi
